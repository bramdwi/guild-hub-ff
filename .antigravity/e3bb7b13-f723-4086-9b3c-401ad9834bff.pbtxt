        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// State update handlers"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "export const addGuildToDB = (guild: Guild, ketuaMember: Member): DBState => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const db = getDB();"
