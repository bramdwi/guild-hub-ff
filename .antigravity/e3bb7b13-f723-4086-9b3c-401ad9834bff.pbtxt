          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "export const getDB = (): DBState => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (typeof window === \"undefined\") return SEED_DATA;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const raw = localStorage.getItem(LOCAL_STORAGE_KEY);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (!raw) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    localStorage.setItem(LOCAL_STORAGE_KEY, JSON.stringify(SEED_DATA));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return SEED_DATA;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  try {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return JSON.parse(raw);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  } catch (e) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    console.error(\"Failed to parse LocalStorage DB, resetting\", e);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    localStorage.setItem(LOCAL_STORAGE_KEY, JSON.stringify(SEED_DATA));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return SEED_DATA;"
